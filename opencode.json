{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/gpt-5.4",
  "server": {
    "port": 4096,
    "hostname": "127.0.0.1"
  },
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "agent": {
    "build": {
      "description": "Terraform code generation agent for importing and generating HCL from cloud resources",
      "mode": "primary",
      "permission": {
        "*": "allow",
        "doom_loop": "ask",
        "external_directory": "allow"
      }
    }
  },
  "default_agent": "build",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "write": "allow",
    "list": "allow"
  },
  "instructions": [
    ".agents/skills/code-generation/skills/terraform-style-guide/SKILL.md"
  ],
  "plugin": [
    ".agents/skills/code-generation/.claude-plugin/plugin.json"
  ]
}
